{
  "version": 2,
  "redirects": [
    { "source": "/video", "destination": "/video_replit", "permanent": true },
    { "source": "/videos", "destination": "/video_replit", "permanent": true },
    { "source": "/videos_replit", "destination": "/video_replit", "permanent": true },
    { "source": "/blog", "destination": "https://blog.tejadi-0.me", "statusCode": 301 },
    { "source": "/blog/:path*", "destination": "https://blog.tejadi-0.me/:path*", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
